<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.ctrlaltquest.ui.controllers.LoginController"
            stylesheets="/styles/auth.css" prefWidth="1280" prefHeight="720">
    
    <MediaView fx:id="backgroundVideo" fitWidth="1280" fitHeight="720" preserveRatio="false" />

    <BorderPane styleClass="main-container">
        <top>
            <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="top-bar" style="-fx-padding: 25;">
                <Button text="⚙" onAction="#handleOpenSettings" styleClass="icon-button" focusTraversable="false" />
            </HBox>
        </top>
        
        <left>
            <VBox spacing="0" styleClass="sidebar" alignment="TOP_CENTER">
                <VBox alignment="CENTER" prefHeight="280" spacing="15">
                    <ImageView fx:id="sidebarLogo" fitHeight="130" preserveRatio="true" />
                    <Label text="CTRL + ALT + QUEST" styleClass="sidebar-title-runic" />
                </VBox>

                <VBox alignment="TOP_CENTER" spacing="25" VBox.vgrow="ALWAYS">
                    <StackPane fx:id="carouselContainer" styleClass="carousel-viewport-clean">
                        <StackPane fx:id="newsSlider">
                            
                            <VBox styleClass="news-card-compact" alignment="TOP_LEFT">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="✦" styleClass="bullet-icon-gold"/>
                                    <Label text="ACTUALIZACIÓN" styleClass="card-category-runic" />
                                </HBox>
                                <Label text="Se han corregido los pergaminos de inicio de sesión para una experiencia más mágica y fluida." 
                                       wrapText="true" styleClass="card-text-pixel" />
                            </VBox>
                            
                            <VBox styleClass="news-card-compact" alignment="TOP_LEFT">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="⚔" styleClass="bullet-icon-gold"/>
                                    <Label text="ANUNCIOS" styleClass="card-category-runic" />
                                </HBox>
                                <Label text="El torneo de hojas de cálculo comienza este viernes. ¿Tienes tu macro lista para el combate?" 
                                       wrapText="true" styleClass="card-text-pixel" />
                            </VBox>

                        </StackPane>
                    </StackPane>
                    
                    <HBox alignment="CENTER" spacing="12" styleClass="carousel-dots">
                        <Circle radius="5" styleClass="dot, active-dot"/>
                        <Circle radius="5" styleClass="dot"/>
                    </HBox>
                </VBox>
            </VBox>
        </left>

        <center>
            <StackPane>
                <VBox alignment="CENTER" spacing="30" maxWidth="550" maxHeight="520" styleClass="auth-panel">
                    <Label text="BIENVENIDO AVENTURERO" styleClass="auth-title-hero" 
                           wrapText="true" textAlignment="CENTER" maxWidth="Infinity" />
                    
                    <VBox spacing="20" styleClass="input-group">
                        <VBox spacing="8">
                            <Label text="IDENTIDAD" styleClass="input-label-runic-gold"/>
                            <TextField fx:id="usernameField" promptText="Nombre de usuario" styleClass="custom-field" />
                        </VBox>
                        
                        <VBox spacing="8">
                            <Label text="LLAVE MÁGICA" styleClass="input-label-runic-gold"/>
                            <StackPane alignment="CENTER_RIGHT">
                                <PasswordField fx:id="passwordHidden" promptText="Contraseña" styleClass="custom-field" />
                                <TextField fx:id="passwordShown" promptText="Contraseña" styleClass="custom-field" visible="false" />
                                
                                <Button fx:id="btnTogglePassword" 
                                        onAction="#togglePassword" 
                                        text="👁" 
                                        styleClass="btn-eye" 
                                        focusTraversable="false" />
                            </StackPane>
                        </VBox>
                    </VBox>
                    
                    <Button text="INICIAR AVENTURA" onAction="#handleLogin" styleClass="primary-button-hero" />
                    
                    <HBox alignment="CENTER" spacing="40">
                        <Button text="Crear cuenta" onAction="#handleGoToRegister" styleClass="link-button-clean" focusTraversable="false" />
                        <Button text="¿Olvidaste tu llave?" onAction="#handleForgotPassword" styleClass="link-button-clean" focusTraversable="false" />
                    </HBox>
                </VBox>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>
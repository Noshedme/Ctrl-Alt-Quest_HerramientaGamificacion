<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.animation.Timeline?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.ctrlaltquest.ui.controllers.views.ActivityViewController"
      spacing="10" styleClass="view-container" 
      style="-fx-background-color: transparent;">
    <stylesheets>
        <URL value="@/styles/shared.css" />
        <URL value="@/styles/home.css" />
    </stylesheets>

    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <!-- TOP CONTROL PANEL -->
    <HBox spacing="20" alignment="CENTER_LEFT" 
          style="-fx-background-color: linear-gradient(to right, rgba(30, 22, 45, 0.7), rgba(13, 9, 21, 0.7)); -fx-background-radius: 25; -fx-border-color: rgba(247, 210, 122, 0.25); -fx-border-width: 1.5; -fx-border-radius: 25; -fx-padding: 15 30;">
        <effect><DropShadow color="rgba(0,0,0,0.6)" radius="20" offsetY="3"/></effect>

        <Label text="📡 MONITOREO DE ACTIVIDAD" 
               style="-fx-font-family: 'Georgia'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #f7d27a; -fx-letter-spacing: 1px;"/>
        
        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button fx:id="btnCaptureActivity" text="📸 CAPTURAR" 
                    style="-fx-background-color: linear-gradient(to bottom, rgba(247, 210, 122, 0.3), rgba(247, 210, 122, 0.15)); -fx-background-radius: 15; -fx-text-fill: #f7d27a; -fx-font-family: 'Georgia'; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 8 18; -fx-border-color: rgba(247, 210, 122, 0.4); -fx-border-radius: 15; -fx-cursor: hand;"/>
            
            <ToggleButton fx:id="btnToggleMonitor" text="▶ INICIAR" onAction="#handleToggleMonitor" 
                          style="-fx-background-color: linear-gradient(to bottom, #4ade80, #2d7a52); -fx-background-radius: 15; -fx-text-fill: white; -fx-font-family: 'Georgia'; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- ANIMATED VISUAL BAR -->
    <VBox spacing="2" prefHeight="40" maxHeight="40"
          style="-fx-background-color: transparent;">
        <HBox alignment="CENTER" spacing="3" prefHeight="30" maxHeight="30">
            <Rectangle fx:id="bar1" width="18" height="15" fill="rgba(74, 222, 128, 0.5)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar2" width="18" height="20" fill="rgba(74, 222, 128, 0.6)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar3" width="18" height="12" fill="rgba(74, 222, 128, 0.4)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar4" width="18" height="25" fill="rgba(74, 222, 128, 0.7)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar5" width="18" height="18" fill="rgba(74, 222, 128, 0.55)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar6" width="18" height="22" fill="rgba(74, 222, 128, 0.65)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar7" width="18" height="14" fill="rgba(74, 222, 128, 0.45)" arcWidth="2" arcHeight="2"/>
            <Rectangle fx:id="bar8" width="18" height="19" fill="rgba(74, 222, 128, 0.58)" arcWidth="2" arcHeight="2"/>
        </HBox>
        <Label text="⚡ FLUJO DE ACTIVIDAD" 
               style="-fx-font-family: 'Georgia'; -fx-font-weight: bold; -fx-font-size: 9px; -fx-text-fill: #4ade80; -fx-text-alignment: center;" maxHeight="10"/>
    </VBox>

    <!-- ACTIVITY TABLE -->
    <VBox spacing="0" VBox.vgrow="ALWAYS"
          style="-fx-background-color: linear-gradient(to bottom, rgba(30, 22, 45, 0.6), rgba(13, 9, 21, 0.6)); -fx-background-radius: 25; -fx-border-color: rgba(247, 210, 122, 0.2); -fx-border-width: 1.5; -fx-border-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 20, 0, 0, 5);">
        
        <!-- HEADER -->
        <HBox style="-fx-padding: 15 20; -fx-border-color: transparent transparent rgba(247, 210, 122, 0.15) transparent; -fx-border-width: 0 0 1 0;">
            <Label text="📱 APLICACIONES RASTREADAS" 
                   style="-fx-font-family: 'Georgia'; -fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #f7d27a;"/>
        </HBox>
        
        <!-- TABLE -->
        <TableView fx:id="tableLog" VBox.vgrow="ALWAYS" 
                   style="-fx-background-color: transparent; -fx-font-family: 'Verdana'; -fx-font-size: 11px;">
            <placeholder>
                <Label text="👁 Captura actividad para ver las aplicaciones rastreadas..." 
                       style="-fx-text-fill: #666; -fx-font-family: 'Verdana'; -fx-font-size: 11px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colTime" text="⏰ HORA" prefWidth="80" style="-fx-alignment: CENTER-LEFT; -fx-text-fill: #888;"/>
                <TableColumn fx:id="colApp" text="📱 APLICACIÓN" prefWidth="220" style="-fx-text-fill: #ddd;"/>
                <TableColumn fx:id="colStatus" text="✓ ESTADO" prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colDuration" text="⏱ DURACIÓN" prefWidth="80" style="-fx-alignment: CENTER-RIGHT; -fx-text-fill: #888;"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
    </VBox>

    <!-- HIDDEN ELEMENTS REQUIRED BY CONTROLLER -->
    <Circle fx:id="statusIndicator" radius="1" fill="#4ade80" visible="false" managed="false"/>
    <Circle fx:id="radarPulse" radius="1" fill="TRANSPARENT" stroke="#4ade80" strokeWidth="1" opacity="0.0" visible="false" managed="false"/>
    <Rectangle fx:id="decorationLine" width="1" height="1" fill="#4ade80" visible="false" managed="false"/>
    <Label fx:id="lblMonitorStatus" text="OFFLINE" visible="false" managed="false"/>
    <Label fx:id="lblCurrentWindow" text="---" visible="false" managed="false"/>
    <Label fx:id="lblProductivity" text="OFFLINE" visible="false" managed="false"/>
    <Label fx:id="lblSessionTime" text="00:00:00" visible="false" managed="false"/>
    <Label fx:id="lblSessionXP" text="+0 XP" visible="false" managed="false"/>
    <ProgressBar fx:id="signalBar" progress="0.0" visible="false" managed="false"/>
</VBox>
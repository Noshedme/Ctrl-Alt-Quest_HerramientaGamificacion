<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="mainPane" prefHeight="600" prefWidth="800"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ctrlaltquest.ui.controllers.views.KeyBindingsViewController"
            stylesheets="@/styles/shared.css,@/styles/keybindings.css">
    
    <!-- HEADER -->
    <top>
        <VBox style="-fx-padding: 20; -fx-background-color: rgba(20, 15, 35, 0.95); -fx-border-color: rgba(247, 210, 122, 0.15); -fx-border-width: 0 0 1 0;">
            <Label text="⌨️ ATAJOS DE TECLADO" 
                   styleClass="keybindings-header">
            </Label>
            <Label text="Presiona estos atajos en cualquier momento durante el juego"
                   styleClass="keybindings-subtitle">
            </Label>
        </VBox>
    </top>
    
    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-padding: 0;">
            <VBox fx:id="bindingsContainer" spacing="10" styleClass="keybindings-container">
                <!-- Los atajos se cargarán dinámicamente aquí -->
            </VBox>
        </ScrollPane>
    </center>
    
    <!-- FOOTER -->
    <bottom>
        <HBox styleClass="keybindings-footer"
              spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="closeButton" text="Cerrar" 
                    styleClass="btn-action-primary"
                    onAction="#handleClose"/>
        </HBox>
    </bottom>
    
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.ctrlaltquest.ui.controllers.LoginController"
            stylesheets="/styles/auth.css" prefWidth="1280" prefHeight="720">
    
    <MediaView fx:id="backgroundVideo" fitWidth="1280" fitHeight="720" preserveRatio="false" />

    <BorderPane styleClass="main-container">
        <top>
            <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="top-bar">
                <Button text="⚙" styleClass="icon-button" focusTraversable="false" />
            </HBox>
        </top>
        
        <left>
            <VBox spacing="30" styleClass="sidebar">
                <HBox alignment="CENTER_LEFT" spacing="15" styleClass="sidebar-header">
                    <ImageView fx:id="sidebarLogo" fitHeight="50" preserveRatio="true">
                        <image>
                            <Image url="@/assets/images/logo.png" />
                        </image>
                    </ImageView>
                    <Label text="CTRL + ALT + QUEST" styleClass="sidebar-title" />
                </HBox>

                <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                    <StackPane fx:id="carouselContainer" styleClass="news-carousel-viewport">
                        <VBox fx:id="newsSlider" spacing="0">
                            <VBox styleClass="news-card-carousel" prefHeight="450" minHeight="450">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="✦" styleClass="bullet-icon"/>
                                    <Label text="NEWS" styleClass="card-category" />
                                </HBox>
                                <Label text="¡Nuevas herramientas de ofimática han sido añadidas al reino! Domina las tablas dinámicas para avanzar." wrapText="true" styleClass="card-text" />
                            </VBox>
                            <VBox styleClass="news-card-carousel" prefHeight="450" minHeight="450">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="⚔" styleClass="bullet-icon"/>
                                    <Label text="ANUNCIOS" styleClass="card-category" />
                                </HBox>
                                <Label text="El torneo de hojas de cálculo comienza este viernes. ¿Tienes tu macro lista para el combate?" wrapText="true" styleClass="card-text" />
                            </VBox>
                            <VBox styleClass="news-card-carousel" prefHeight="450" minHeight="450">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="📜" styleClass="bullet-icon"/>
                                    <Label text="ACTUALIZACIÓN" styleClass="card-category" />
                                </HBox>
                                <Label text="Se han corregido los pergaminos de inicio de sesión para una experiencia más mágica." wrapText="true" styleClass="card-text" />
                            </VBox>
                        </VBox>
                    </StackPane>
                    
                    <HBox alignment="CENTER" spacing="10" styleClass="carousel-dots">
                        <Circle radius="5" fx:id="dot1" styleClass="dot, active-dot"/>
                        <Circle radius="5" fx:id="dot2" styleClass="dot"/>
                        <Circle radius="5" fx:id="dot3" styleClass="dot"/>
                    </HBox>
                </VBox>
            </VBox>
        </left>

        <center>
            <StackPane>
                <VBox alignment="CENTER" spacing="35" maxWidth="500" styleClass="auth-panel">
                    <Label text="BIENVENIDO AVENTURERO" styleClass="auth-title" />
                    
                    <VBox spacing="25" styleClass="input-group">
                        <VBox spacing="10">
                            <Label text="IDENTIDAD" styleClass="input-label-runic"/>
                            <TextField fx:id="usernameField" promptText="Nombre de usuario" styleClass="custom-field" />
                        </VBox>
                        
<VBox spacing="10">
    <Label text="LLAVE MÁGICA" styleClass="input-label-runic"/>
    <StackPane alignment="CENTER_RIGHT">
        <PasswordField fx:id="passwordHidden" promptText="Contraseña" styleClass="custom-field" />
        <TextField fx:id="passwordShown" promptText="Contraseña" styleClass="custom-field" visible="false" />
        
        <Button fx:id="btnTogglePassword" 
                onAction="#togglePassword" 
                text="👁" 
                styleClass="btn-eye" 
                focusTraversable="false" />
    </StackPane>
</VBox>
                    </VBox>
                    
                    <Button text="INICIAR AVENTURA" onAction="#handleLogin" styleClass="primary-button" />
                    
                    <HBox alignment="CENTER" spacing="40">
                        <Button text="Crear cuenta" onAction="#handleGoToRegister" styleClass="link-button" focusTraversable="false" />
                        <Button text="¿Olvidaste tu llave?" onAction="#handleForgotPassword" styleClass="link-button" focusTraversable="false" />
                    </HBox>
                </VBox>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>
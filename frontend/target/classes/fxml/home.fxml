<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.ctrlaltquest.ui.controllers.HomeController"
           stylesheets="@/styles/home.css">

    <MediaView fx:id="backgroundVideo" preserveRatio="false" />
    <Pane style="-fx-background-color: rgba(0, 0, 0, 0.6);" />

    <BorderPane>
        <top>
            <HBox spacing="30" styleClass="status-header">
                <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                
                <VBox alignment="CENTER_LEFT">
                    <Label fx:id="lblUsername" text="CARGANDO..." styleClass="hero-name"/>
                    <Label fx:id="lblClass" text="CLASE" styleClass="hero-class"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="5">
                    <HBox spacing="10" alignment="CENTER">
                        <Label text="LVL" styleClass="text-lvl"/>
                        <Label fx:id="lblLevel" text="1" styleClass="text-lvl-value"/>
                    </HBox>
                    <ProgressBar fx:id="xpBar" progress="0.0" prefWidth="450" styleClass="custom-xp-bar"/>
                    <Label fx:id="lblXPText" text="0 / 1000 XP" styleClass="text-tiny"/>
                </VBox>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <VBox alignment="CENTER">
                        <Label text="💰 MONEDAS" styleClass="text-label-gold"/>
                        <Label fx:id="lblCoins" text="0" styleClass="text-value-gold"/>
                    </VBox>
                </HBox>
            </HBox>
        </top>

        <left>
            <VBox spacing="15" styleClass="side-menu">
                <padding><Insets top="20" left="15" right="15"/></padding>
                <Button text="MISIONES" onAction="#showMissions" styleClass="btn-nav-active"/>
                <Button text="TIENDA" onAction="#showStore" styleClass="btn-nav"/>
                <Button text="INVENTARIO" onAction="#showInventory" styleClass="btn-nav"/>
                <Button text="ESTADÍSTICAS" onAction="#showStats" styleClass="btn-nav"/>
                <Separator styleClass="menu-separator"/>
                <Button text="AJUSTES" onAction="#showSettings" styleClass="btn-nav"/>
                <Button text="LOGOUT" onAction="#handleLogout" styleClass="btn-nav-danger"/>
            </VBox>
        </left>

        <center>
            <VBox spacing="20">
                <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                <Label text="DIARIO DE AVENTURAS" styleClass="section-title"/>
                <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
                    <VBox fx:id="missionsContainer" spacing="12">
                        <Label text="No hay misiones activas..." textFill="gray"/>
                    </VBox>
                </ScrollPane>
            </VBox>
        </center>

        <right>
            <VBox spacing="20" prefWidth="280" styleClass="activity-panel">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="ESTADO DE ACTIVIDAD" styleClass="section-title-small"/>
                
                <VBox styleClass="activity-card">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label text="APP EN FOCO" styleClass="text-tiny-bright"/>
                    <Label fx:id="lblCurrentApp" text="Detectando..." styleClass="text-app-name"/>
                    <Label fx:id="lblAppStatus" text="DESCONOCIDO" styleClass="status-tag"/>
                </VBox>

                <VBox styleClass="health-card">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label text="Racha de Salud" styleClass="text-tiny-bright"/>
                    <Label fx:id="lblHealthStreak" text="0 min" styleClass="text-health-value"/>
                    <ProgressBar fx:id="healthBar" progress="1.0" styleClass="health-progress"/>
                </VBox>
            </VBox>
        </right>
    </BorderPane>

    <VBox fx:id="loadingLayer" visible="false" styleClass="loading-overlay" alignment="CENTER">
        <ProgressIndicator />
    </VBox>
</StackPane>
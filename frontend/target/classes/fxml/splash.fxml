<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:id="root"
           fx:controller="com.ctrlaltquest.ui.controllers.SplashController"
           stylesheets="/styles/splash.css"
           prefWidth="1280"
           prefHeight="720"
           style="-fx-background-color: #0d0b1a;">

    <!-- CAPA 1: Fondo — login_bg.png con parallax animado por controller -->
    <ImageView fx:id="splashBg"
               fitWidth="1400" fitHeight="810"
               preserveRatio="false"
               mouseTransparent="true" />

    <!-- CAPA 2: Overlay oscuro para dar contraste al contenido -->
    <StackPane mouseTransparent="true"
               style="-fx-background-color: rgba(8, 5, 20, 0.52);" />

    <!-- CAPA 3: Contenido principal -->
    <VBox alignment="CENTER" spacing="30">

        <!-- Logo con pulso + brillo animado por controller -->
        <ImageView fx:id="splashLogo"
                   fitHeight="130"
                   preserveRatio="true" />

        <Label text="CTRL + ALT + QUEST" styleClass="splash-title" />

        <VBox alignment="CENTER" spacing="10" maxWidth="500">
            <ProgressBar fx:id="loadingBar"
                         prefWidth="500"
                         progress="0"
                         styleClass="splash-progress" />
            <Label fx:id="loadingText"
                   text="Iniciando Stack Tech..."
                   styleClass="splash-text" />
        </VBox>

    </VBox>

</StackPane>
